# FinLayer API — Environment Variables
# Copy to .env.local for local development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finlayer:finlayer_dev_password@localhost:5432/finlayer

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
API_BASE_URL=http://localhost:3000

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Get your ChangeNOW API key at: https://changenow.io/api
CHANGENOW_API_KEY=your_changenow_api_key_here

# Alchemy (Phase 4) — multi-chain balance queries
# Get a key at: https://www.alchemy.com
# ALCHEMY_API_KEY=your_alchemy_key

# Phase 2+
# MOONPAY_API_KEY=your_moonpay_key
# TRANSAK_API_KEY=your_transak_key
# AAVE_RPC_URL=https://mainnet.infura.io/v3/your_key

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Wallet (Phase 4) ─────────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM encryption of stored BIP39 mnemonics.
# Accepts 64-char hex or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WALLET_ENCRYPTION_KEY=

# ─── Affiliate Payout Scheduler (Phase 4) ─────────────────────────────────────
# Set to true to enable periodic automated affiliate payout batch creation.
# PAYOUT_SCHEDULER_ENABLED=false
# PAYOUT_INTERVAL_MS=3600000          # default: 1 hour
# PAYOUT_MIN_AMOUNT=1.0                # minimum batch amount in PAYOUT_ASSET
# PAYOUT_ASSET=USDC

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your_sentry_dsn
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
