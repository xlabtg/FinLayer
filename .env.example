# FinLayer API — Environment Variables
# Copy to .env.local for local development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://finlayer:finlayer_dev_password@localhost:5432/finlayer

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
API_BASE_URL=http://localhost:3000

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Get your ChangeNOW API key at: https://changenow.io/api
CHANGENOW_API_KEY=your_changenow_api_key_here
# Shared secret used to verify signed swap webhooks (x-changenow-signature).
# Required for POST /v1/swap/webhook/:id — deliveries are rejected until it is set.
CHANGENOW_WEBHOOK_SECRET=your_changenow_webhook_secret_here

# Alchemy (Phase 4) — multi-chain balance queries. Also reused as RPC URL
# for Phase 3 earn adapters if AAVE_RPC_URL / COMPOUND_RPC_URL are unset.
# Get a key at: https://www.alchemy.com
# ALCHEMY_API_KEY=your_alchemy_key

# ─── Payments (Phase 2) ───────────────────────────────────────────────────────
# Get your MoonPay keys at: https://dashboard.moonpay.com
# MOONPAY_API_KEY=your_moonpay_api_key
# MOONPAY_WEBHOOK_SECRET=your_moonpay_webhook_secret

# Get your Transak keys at: https://transak.com/developer-portal
# TRANSAK_API_KEY=your_transak_api_key
# TRANSAK_WEBHOOK_SECRET=your_transak_webhook_secret

# Get your NowPayments keys at: https://account.nowpayments.io
# NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

# ─── Earn / Lending (Phase 3) ─────────────────────────────────────────────────
# RPC URL = Alchemy / Infura / any JSON-RPC endpoint.
# Without these set, strategy listing still works but deposits/withdrawals
# will return a 400 "client not configured" error.
# AAVE_RPC_URL=https://mainnet.infura.io/v3/your_key
# COMPOUND_RPC_URL=https://mainnet.infura.io/v3/your_key

# ─── Phase 5: Growth & Ecosystem ──────────────────────────────────────────────
# Base URL used by the Marketplace affiliate link generator.
MARKETPLACE_BASE_URL=https://finlayer.io

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Comma-separated origins allowed as final destinations for /r/:code affiliate redirects.
# Defaults to MARKETPLACE_BASE_URL and API_BASE_URL when unset.
AFFILIATE_REDIRECT_ALLOWED_ORIGINS=https://finlayer.io,http://localhost:3000,http://localhost:3001

# ─── Wallet (Phase 4) ─────────────────────────────────────────────────────────
# 32-byte key for AES-256-GCM encryption of stored BIP39 mnemonics.
# Accepts 64-char hex or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WALLET_ENCRYPTION_KEY=

# ─── Affiliate Payout Scheduler (Phase 4) ─────────────────────────────────────
# Set to true to enable periodic automated affiliate payout batch creation.
# PAYOUT_SCHEDULER_ENABLED=false
# PAYOUT_INTERVAL_MS=3600000          # default: 1 hour
# PAYOUT_MIN_AMOUNT=1.0                # minimum batch amount in PAYOUT_ASSET
# PAYOUT_ASSET=USDC

# ─── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your_sentry_dsn
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
